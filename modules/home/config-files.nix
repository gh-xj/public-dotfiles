{ config, lib, publicDotfilesDelivery, ... }:

let
  cfg = config.xj.publicDotfiles;
  inherit (publicDotfilesDelivery)
    mkGeneratedText
    mkImmutableFile
    mkImmutableTree
    mkRepoFile
    mkRepoTree
    ;
in
{
  config = lib.mkIf cfg.enable {
    home.file = {
      ".amethyst.yml" = mkRepoFile ".config/amethyst/amethyst.yml";
      "Taskfile.yml" = mkRepoFile "global/Taskfile.yml" // { force = true; };
      ".tmux.conf" = mkGeneratedText ''
        # Generated by Home Manager from public-dotfiles. Do not edit.
        source-file ~/.config/tmux/tmux.conf
      '';
      ".zprofile" = mkRepoFile ".zprofile";
      ".zshrc" = mkRepoFile ".zshrc";
    };

    xdg.configFile = {
      "bat" = mkImmutableTree ".config/bat";
      "amethyst" = mkRepoTree ".config/amethyst";
      "karabiner" = mkRepoTree ".config/karabiner";
      "lazygit" = mkImmutableTree ".config/lazygit";
      "nvim" = mkRepoTree ".config/nvim";
      "opencode" = mkRepoTree ".config/opencode";
      "raycast/scripts" = mkRepoTree ".config/raycast/scripts";
      "xj_public_raycast_scripts" = mkRepoTree ".config/raycast/scripts";
      "starship.toml" = mkImmutableFile ".config/starship.toml";
      "yazi" = mkImmutableTree ".config/yazi";
    };
  };
}
