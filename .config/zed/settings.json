// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  "use_system_window_tabs": false,
  "icon_theme": {
    "light": "Colored Zed Icons Theme Light",
    "dark": "Colored Zed Icons Theme Dark",
    "mode": "system"
  },
  "file_finder": {
    "modal_max_width": "medium"
  },
  "edit_predictions": {
    "provider": "none",
    "disabled_globs": [
      ".env"
    ]
  },
  "outline_panel": {
    "dock": "right",
    "default_width": 400
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark Pro"
  },
  // "tab_bar": {
  //   "show_tab_bar_buttons": false,
  //   "show_nav_history_buttons": false,
  //   // "show": false
  // },
  // "redact_private_values": true,
  "experimental.theme_overrides": {
    // "editor.background": "#191831",
    "syntax": {
      "comment": {
        "font_style": "italic"
      }
    }
  },
  "use_system_path_prompts": false,
  "vim": {
    "use_smartcase_find": true
  },
  "vim_mode": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "git": {
    "inline_blame": {
      "enabled": false,
      "show_commit_summary": true,
      "delay_ms": 500
    }
  },
  // "ui_font_family": "Iosevka Nerd Font",
  // "ui_font_family": "FiraCode Nerd Font",
  // "ui_font_family": "JetBrainsMono Nerd Font",
  // "ui_font_family": "Monaspace Krypton",
  // "ui_font_family": "Monaspace Radon",
  // "ui_font_family": "Lilex",
  // "ui_font_family": "RecMonoCasual Nerd Font Mono",
  // "ui_font_family": "Mona Sans",
  "ui_font_family": "Recursive",
  "ui_font_size": 16,
  // "ui_font_weight": 700,
  // "buffer_font_family": "Fira Mono",
  // "buffer_font_family": "FiraCode Nerd Font",
  // "buffer_font_family": "JetBrainsMono Nerd Font",
  // "buffer_font_family": "VictorMono Nerd Font",
  // "buffer_font_family": "RecMonoCasual Nerd Font",
  // "buffer_font_family": "RecMonoLinear Nerd Font",
  // "buffer_font_family": "RecMonoDuotone Nerd Font",
  // "buffer_font_family": "Monaspace Neon",
  // "buffer_font_family": "Recursive Monospace",
  // "buffer_font_family": "RecMonoLinear Nerd Font",
  // "buffer_font_family": "Recursive",
  // "buffer_font_family": "Iosevka Nerd Font",
  "buffer_font_family": "Monaspace Argon",
  // "buffer_font_weight": 550,
  // "buffer_font_family": "Maple Mono NF CN",
  // "buffer_font_family": "Mona Sans",
  // "buffer_font_family": "FZPingXianYaSongS-R-GB",
  // "buffer_font_weight": 700,
  // "buffer_font_family": "RecMonoDuotone Nerd Font",
  // "buffer_font_weight": 600,
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "ss01": true,
    "ss02": true,
    "ss03": true,
    "ss04": true,
    "ss05": true,
    "ss06": true,
    "ss07": true,
    "ss08": true,
    "ss09": true
  },
  // "buffer_font_family": "MonaspiceNe Nerd Font",
  "terminal": {
    "default_height": 800,
    "dock": "bottom",
    "font_family": "RecMonoDuotone Nerd Font",
    "toolbar": {
      "breadcrumbs": true
    },
    // "font_family": "RecMonoLinear Nerd Font",
    // "font_family": "RecMonoCasual Nerd Font",
    // "font_family": "RecMonoCasual Nerd Font Mono",
    // "font_family": "Maple Mono NF CN",
    // "font_family": "MonaspiceRn Nerd Font",
    // "font_family": "FiraCode Nerd Font",
    // "font_family": "Recursive",
    // "font_family": "JetBrainsMono Nerd Font",
    "env": {
      "EDITOR": "nvim",
      "ZED_NOTIFY_TERMINAL": "1"
    },
    "shell": {
      "program": "/bin/zsh"
    }
  },
  "soft_wrap": "editor_width",
  "languages": {
    "Go": {
      "code_actions_on_format": {
        "source.organizeImports": true
      },
      "language_servers": [
        "gopls",
        "golangci-lint"
      ],
      "format_on_save": "on"
    },
    "Markdown": {
      "format_on_save": "on",
      "tab_size": 2,
      "auto_indent_on_paste": false
      // "formatter": "language_server"
      // "show_completions_on_input": false
    },
    "JSON": {
      // (https://github.com/zed-industries/zed/issues/10122#issuecomment-2672752630)
      "formatter": {
        "external": {
          "command": "jq",
          "arguments": [
            ".",
            "-"
          ]
        }
      }
    },
    "JSONC": {
      "formatter": "language_server",
      "format_on_save": "on"
    },
    "Python": {
      "format_on_save": "on",
      "language_servers": [
        "pyright",
        "pylsp",
        "ruff"
      ],
      "formatter": [
        {
          "code_action": "source.organizeImports.ruff"
        },
        {
          "code_action": "source.fixAll.ruff"
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  },
  "lsp": {
    "vtsls": {
      "settings": {
        // For JavaScript:
        "javascript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": false
            },
            "parameterTypes": {
              "enabled": true
            },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true
            },
            "propertyDeclarationTypes": {
              "enabled": true
            },
            "functionLikeReturnTypes": {
              "enabled": true
            },
            "enumMemberValues": {
              "enabled": true
            }
          }
        },
        // For TypeScript:
        "typescript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": false
            },
            "parameterTypes": {
              "enabled": true
            },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true
            },
            "propertyDeclarationTypes": {
              "enabled": true
            },
            "functionLikeReturnTypes": {
              "enabled": true
            },
            "enumMemberValues": {
              "enabled": true
            }
          }
        }
      }
    },
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true
          },
          "closureReturnTypeHints": {
            "enable": "always"
          }
        }
      }
    },
    "thrift-ls": {
      "binary": {
        "path_lookup": true
      }
    },
    "typos": {
      "initialization_options": {
        // Path to your typos config file, .typos.toml by default.
        "config": ".typos.toml",
        // Path to your typos-lsp executable, takes $PATH into account.
        "path": "typos-lsp",
        // Diagnostic severity within Zed. "Error" by default, can be:
        // "Error", "Hint", "Information", "Warning"
        "diagnosticSeverity": "Error",
        // Minimum logging level for the LSP, displayed in Zed's logs. "info" by default, can be:
        // "debug", "error", "info", "off", "trace", "warn"
        "logLevel": "info",
        // Traces the communication between ZED and the language server. Recommended for debugging only. "off" by default, can be:
        // "messages", "off", "verbose"
        "trace.server": "off"
      }
    },
    "golangci-lint": {
      // [zed-extensions/golangci-lint: Zed Extension for golangci-lint](https://github.com/zed-extensions/golangci-lint)
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path=stdout",
          "--output.text.path=",
          "--show-stats=false",
          "--tests"
        ]
      }
    },
    "gopls": {
      "initialization_options": {
        "buildFlags": [
          "-tags=wireinject"
        ],
        "standaloneTags": [
          "wireinject"
        ],
        "env": {
          "GOFLAGS": "-tags=wireinject"
        },
        "gofumpt": true,
        "directoryFilters": [
          "-node_modules",
          "-vendor",
          "-docs"
        ],
        "templateExtensions": [],
        "analyses": {
          "revive": true,
          "unusedparams": false,
          "unusedwrite": false
        },
        "staticcheck": false
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          // Ruff server settings goes here
          "lineLength": 80,
          "lint": {
            "extendSelect": [
              "I"
            ]
          }
        }
      }
    }
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    // "show_background": true,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50
  },
  "always_treat_brackets_as_autoclosed": true,
  "format_on_save": "off", // Global formatting for any type of files breaks a lot of things for existing projects.
  // Indentation, rainbow indentation
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "title_bar": {
    "show_user_picture": false,
    "show_onboarding_banner": false
  },
  "search": {
    "case_sensitive": false
    // "regex": true
  },
  "active_pane_modifiers": {
    "border_size": 1
    // "magnification": 1.5
  },
  // "seed_search_query_from_cursor": "selection",
  "extend_comment_on_newline": false,
  "gutter": {
    "folds": false,
    "runnables": false
  },
  "go_to_definition_fallback": "find_all_references",
  "debugger": {
    "dock": "left"
  },
  "when_closing_with_no_tabs": "keep_window_open"
}
