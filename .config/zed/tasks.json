// Static tasks configuration.
//
// Example:
[
  {
    "label": "yazi_cur",
    "command": "yazi \"$ZED_FILE\"",
    "hide": "on_success",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "shell": {
      "program": "sh"
    }
  },
  {
    "label": "start lazygit",
    "command": "lazygit -p $ZED_WORKTREE_ROOT",
    "hide": "on_success",
    "shell": {
      "program": "sh"
    }
  },
  {
    "label": "start lazygit file log",
    "command": "lazygit",
    "args": [
      "-f",
      "\"$ZED_RELATIVE_FILE\""
    ],
    "hide": "on_success",
    "shell": {
      "program": "sh"
    }
  },
  {
    "label": "New request md doc",
    "command": "~/.config/zed/scripts/zed-new-request-doc.sh",
    "env": {
      "XJ_EDITOR_OPEN": "/opt/homebrew/bin/zed"
    },
    "reveal": "never",
    "hide": "always",
    "allow_concurrent_runs": true,
    "shell": "system"
  },
  {
    "label": "Paste Image",
    "command": "~/.config/zed/scripts/zed-image-paste.sh",
    "env": {
      "IMG_SAVE_PATH": "attachments"
    },
    "use_new_terminal": true,
    "allow_concurrent_runs": true,
    "reveal": "never",
    "hide": "always",
    "shell": "system"
  }
]
