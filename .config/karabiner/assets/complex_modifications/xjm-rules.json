{
  "name": "xjm-rules",
  "rules": [
    {
      "description": "Microsoft Edge navigation keys",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.microsoft\\.edgemac$"]
            }
          ],
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": ["command", "control"]
            }
          },
          "to": [
            {
              "key_code": "f6"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.microsoft\\.edgemac$"]
            }
          ],
          "from": {
            "key_code": "l",
            "modifiers": {
              "mandatory": ["command", "control"]
            }
          },
          "to": [
            {
              "key_code": "f6",
              "modifiers": ["shift"]
            }
          ]
        }
      ]
    },
    {
      "description": "Feishu: Convert Ctrl + S to Option + Tab",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.electron\\.lark$"]
            }
          ],
          "from": {
            "key_code": "s",
            "modifiers": {
              "mandatory": ["control"]
            }
          },
          "to": [
            {
              "key_code": "tab",
              "modifiers": ["option"]
            }
          ]
        }
      ]
    },
    {
      "description": "Zed: Convert Ctrl + S to Ctrl + Tab",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^dev\\.zed\\.Zed$"]
            }
          ],
          "from": {
            "key_code": "s",
            "modifiers": {
              "mandatory": ["control"]
            }
          },
          "to": [
            {
              "key_code": "tab",
              "modifiers": ["control"]
            }
          ]
        }
      ]
    },
    {
      "description": "Extend Ctrl + W to delete word only in text fields",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": [
                "dev.warp.Warp-Stable",
                "^dev\\.zed\\.Zed$",
                "com.mitchellh.ghostty"
              ]
            }
          ],
          "from": {
            "key_code": "w",
            "modifiers": {
              "mandatory": ["control"]
            }
          },
          "to": [
            {
              "key_code": "delete_or_backspace",
              "modifiers": ["option"]
            }
          ]
        }
      ]
    },
    {
      "description": "[xj] jk simultaneous to esc",
      "manipulators": [
        {
          "from": {
            "simultaneous": [
              {
                "key_code": "j"
              },
              {
                "key_code": "k"
              }
            ]
          },
          "to": [
            {
              "key_code": "escape"
            }
          ],
          "type": "basic"
        },
        {
          "from": {
            "simultaneous": [
              {
                "key_code": "j"
              },
              {
                "key_code": "k"
              }
            ],
            "modifiers": {
              "mandatory": ["command"]
            }
          },
          "to": [
            {
              "key_code": "escape",
              "modifiers": ["command"]
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "[xj] right command hyper keys",
      "manipulators": [
        {
          "from": {
            "key_code": "right_command",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_control",
              "modifiers": ["right_shift", "right_command", "right_option"]
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "[button1] basic mode",
      "manipulators": [
        {
          "from": {
            "pointing_button": "button1",
            "modifiers": {
              "optional": [],
              "mandatory": []
            }
          },
          "to": [
            {
              "key_code": "right_control"
            }
          ],
          "to_if_alone": [
